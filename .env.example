# Vor dem Festival kopieren nach .env und echte Werte eintragen:
#   cp .env.example .env
#
# HUB_JWT_SECRET: langer, zufälliger String (z. B. `openssl rand -hex 32`)
HUB_JWT_SECRET=

# HUB_ADMIN_BOOTSTRAP_PIN: PIN für den automatisch angelegten Admin-Account
# (Festival-ID "admin"). Nach dem ersten Login unbedingt Rolle prüfen und
# diesen PIN nur intern weitergeben.
HUB_ADMIN_BOOTSTRAP_PIN=

# CLOUDFLARE_TUNNEL_TOKEN: Token aus dem Cloudflare Zero Trust Dashboard
# (Networks > Tunnels > Tunnel anlegen > Connector-Typ Docker). Siehe
# docs/REMOTE_ACCESS.md für die vollständige Anleitung.
CLOUDFLARE_TUNNEL_TOKEN=

# HUB_VAPID_PUBLIC_KEY / HUB_VAPID_PRIVATE_KEY: Schlüsselpaar für Web Push
# (Push-Benachrichtigungen bei Challenges/Fotos/Trichtern). Einmalig erzeugen
# mit `npx web-push generate-vapid-keys` (benötigt Node, z. B. lokal im
# frontend/-Ordner ausführbar). Siehe docs/PUSH_NOTIFICATIONS.md.
HUB_VAPID_PUBLIC_KEY=
HUB_VAPID_PRIVATE_KEY=

# HUB_VAPID_ADMIN_EMAIL: Kontakt-Mailadresse für den VAPID-Claim (wird von
# Push-Diensten wie z. B. Mozilla bei Problemen kontaktiert, nicht öffentlich
# sichtbar). Beliebige echte Adresse reicht.
HUB_VAPID_ADMIN_EMAIL=
